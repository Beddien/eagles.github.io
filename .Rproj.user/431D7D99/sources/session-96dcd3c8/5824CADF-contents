# 1. Stage and commit your files first
git add --all
git commit -m "initial commit"

# 2. Force the branch name to main
git branch -M main

# 3. Clear any broken 'origin' links and add the correct one
git remote remove origin 2>/dev/null || true
git remote add origin https://github.com/Beddien/Beddien.github.io.git

# 4. Push to GitHub
git push -u origin main