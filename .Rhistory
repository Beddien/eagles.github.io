ggplot() + theme_void() +
geom_polygon(data = map, aes(x = long, y = lat, group = group),
fill = "lightgray", color = 'gray') +
geom_point(data = counts, aes(x = lng, y = lat, size = Freq),
color = "brown", alpha = 0.7) +
scale_size_continuous(range = c(1, 4), name = "Frequency") +
coord_fixed(1.3)
