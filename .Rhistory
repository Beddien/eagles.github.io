#| echo: false
library(tidyverse)
library(ggplot2)
library(maps)
library(pandoc)
#| echo: false
ME5 <- read.csv("MantisEagles.csv")
ME5 = ME5[20:50]
#| echo: false
map = map_data("world")
ggplot() + theme_void() +
geom_polygon(data = map, aes(x = long, y = lat, group = group),
fill = "lightgray", color = 'gray') +
geom_point(data = counts, aes(x = lng, y = lat, size = Freq),
color = "brown", alpha = 0.7) +
scale_size_continuous(range = c(1, 4), name = "Frequency") +
coord_fixed(1.3)
#| echo: false
df2 <- data.frame(t(ME5[-1]))
colnames(df2) <- ME5[, 1]
#| echo: false
df2 <- data.frame(t(counts[-1]))
colnames(df2) <- counts[, 1]
View(df2)
#| echo: false
df2 = df2[1:221]
#| echo: false
df2 <- df2[2:221]
#| echo: false
dffirst <- df2[1:207]
View(dffirst)
#| echo: false
dfsecond = df2[215:220]
View(dfsecond)
#| echo: false
df3 = dffirst + dfsecond
#| echo: false
df3 = data.frame(dffirst[1:207], dfsecond[1:6])
View(df3)
#| echo: false
df2 <- data.frame(t(df3[-1]))
colnames(df2) <- df3[, 1]
#| echo: false
newcounts <- data.frame(t(df3[-1]))
colnames(newcounts) <- df3[, 1]
View(newcounts)
#| echo: false
map = map_data("world")
ggplot() + theme_void() +
geom_polygon(data = map, aes(x = long, y = lat, group = group),
fill = "lightgray", color = 'gray') +
geom_point(data = newcounts, aes(x = lng, y = lat, size = Freq),
color = "brown", alpha = 0.7) +
scale_size_continuous(range = c(1, 4), name = "Frequency") +
coord_fixed(1.3)
View(newcounts)
View(counts)
